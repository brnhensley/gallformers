{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Gall Record",
  "description": "Schema for gall-host association records extracted from scholarly text",
  "type": "object",
  "required": ["gall_species", "host_species", "traits", "description", "confidence"],
  "additionalProperties": false,
  "properties": {
    "gall_species": {
      "type": "object",
      "description": "Taxonomy of the gall-inducing species",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": ["string", "null"],
          "description": "Scientific name of gall species (Genus species)"
        },
        "authority": {
          "type": ["string", "null"],
          "description": "Author citation for the name"
        },
        "family": {
          "type": ["string", "null"],
          "description": "Taxonomic family"
        },
        "order": {
          "type": ["string", "null"],
          "description": "Taxonomic order"
        }
      }
    },
    "host_species": {
      "type": "object",
      "description": "Taxonomy of the host plant species",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": ["string", "null"],
          "description": "Scientific name of host species"
        },
        "authority": {
          "type": ["string", "null"],
          "description": "Author citation for the name"
        },
        "family": {
          "type": ["string", "null"],
          "description": "Taxonomic family (e.g., Fagaceae)"
        }
      }
    },
    "traits": {
      "type": "object",
      "description": "Morphological traits of the gall",
      "additionalProperties": false,
      "properties": {
        "shape": {
          "$ref": "#/definitions/trait_value"
        },
        "color": {
          "$ref": "#/definitions/trait_value"
        },
        "texture": {
          "$ref": "#/definitions/trait_value"
        },
        "walls": {
          "$ref": "#/definitions/trait_value"
        },
        "cells": {
          "$ref": "#/definitions/trait_value"
        },
        "alignment": {
          "$ref": "#/definitions/trait_value"
        },
        "plant_part": {
          "$ref": "#/definitions/trait_value"
        },
        "form": {
          "$ref": "#/definitions/trait_value"
        },
        "season": {
          "$ref": "#/definitions/trait_value"
        },
        "detachable": {
          "type": ["string", "null"],
          "description": "Whether the gall detaches from the host plant",
          "enum": ["unknown", "integral", "detachable", "both", null]
        }
      }
    },
    "description": {
      "type": "string",
      "description": "Morphological description of the gall"
    },
    "location": {
      "type": ["string", "null"],
      "description": "Collection locality"
    },
    "confidence": {
      "type": "number",
      "description": "Confidence in extraction accuracy (0.0 to 1.0)",
      "minimum": 0.0,
      "maximum": 1.0
    }
  },
  "definitions": {
    "trait_value": {
      "type": "object",
      "description": "A trait with original text and suggested vocabulary mappings",
      "additionalProperties": false,
      "properties": {
        "original": {
          "type": ["string", "null"],
          "description": "Exact text from source"
        },
        "suggested": {
          "type": "array",
          "description": "Mapped vocabulary values",
          "items": {
            "type": "string"
          },
          "default": []
        }
      }
    },
    "shape_vocab": {
      "type": "string",
      "enum": [
        "cluster",
        "conical",
        "cup",
        "cylindrical",
        "globular",
        "hemispherical",
        "linear",
        "numerous",
        "rosette",
        "spangle/button",
        "sphere",
        "spindle",
        "tuft"
      ]
    },
    "color_vocab": {
      "type": "string",
      "enum": [
        "UV",
        "black",
        "brown",
        "gray",
        "green",
        "orange",
        "pink",
        "purple",
        "red",
        "tan",
        "white",
        "yellow"
      ]
    },
    "texture_vocab": {
      "type": "string",
      "enum": [
        "areola",
        "bumpy",
        "erineum",
        "glaucous",
        "hairless",
        "hairy",
        "honeydew",
        "leafy",
        "mealy",
        "mottled",
        "pubescent",
        "resinous dots",
        "ribbed",
        "ruptured/split",
        "spiky/thorny",
        "spotted",
        "stiff",
        "striped",
        "succulent",
        "woolly",
        "wrinkly"
      ]
    },
    "walls_vocab": {
      "type": "string",
      "enum": [
        "false chamber",
        "mycelium lining",
        "ostiole",
        "radiating-fibers",
        "slit",
        "spongy",
        "thick",
        "thin"
      ]
    },
    "cells_vocab": {
      "type": "string",
      "enum": [
        "free-rolling",
        "monothalamous",
        "not applicable",
        "polythalamous"
      ]
    },
    "alignment_vocab": {
      "type": "string",
      "enum": [
        "drooping",
        "erect",
        "integral",
        "leaning",
        "supine"
      ]
    },
    "plant_part_vocab": {
      "type": "string",
      "enum": [
        "at leaf vein angles",
        "between leaf veins",
        "bud",
        "flower",
        "fruit",
        "leaf edge",
        "leaf midrib",
        "lower leaf",
        "on leaf veins",
        "petiole",
        "stem",
        "underground (roots+)",
        "upper leaf"
      ]
    },
    "form_vocab": {
      "type": "string",
      "enum": [
        "abrupt swelling",
        "bullet",
        "hidden cell",
        "leaf blister",
        "leaf curl",
        "leaf edge fold",
        "leaf edge roll",
        "leaf snap",
        "leaf spot",
        "modified capitulum",
        "non-gall",
        "oak apple",
        "pip",
        "plum",
        "pocket",
        "rust",
        "scale",
        "stem club",
        "tapered swelling",
        "witches broom"
      ]
    },
    "season_vocab": {
      "type": "string",
      "enum": [
        "Fall",
        "Spring",
        "Summer",
        "Winter"
      ]
    }
  }
}
