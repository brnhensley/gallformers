# Exclude from Docker build context to reduce upload size and build time.

# Git
.git

# Build / test artifacts
/_build/
/deps/
/cover/
/doc/
/test/
/tmp/
*.ez
.elixir_ls
erl_crash.dump

# Assets rebuilt inside Docker
/assets/node_modules/
/priv/static/assets/
/priv/static/cache_manifest.json

# Local databases (~260MB+ combined)
/priv/gallformers.sqlite
/priv/gallformers.sqlite-*
/priv/gallformers_test.sqlite
/priv/gallformers_test.sqlite-*
/priv/data/wcvp_test.sqlite
/priv/data/wcvp_test.sqlite-*

# Volume-backed data files (served via symlink from /data volume)
/priv/static/data/

# Large reference/import data not needed at runtime
/priv/repo/data/wcvp/
/priv/repo/data/reconciliation/

# WCVP databases (downloaded from S3 at build/boot time)
/priv/data/wcvp.sqlite
/priv/data/wcvp.sqlite-*

# Dev logs
/priv/logs/

# Secrets
.env

# Non-application directories
/.claude/
/docs/
/infra/
/runbooks/
/services/
