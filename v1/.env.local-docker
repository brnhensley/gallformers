# Environment
NODE_ENV=development

# Database
DATABASE_URL=file:/usr/src/app/prisma/gallformers.sqlite

# API and Auth URLs
API_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# S3 Configuration
S3_BUCKET=gallformers
AWS_REGION=us-east-1
S3_BACKUP_PATH=backups

# Application paths
APP_PATH=/usr/src/app
BACKUP_PATH=/usr/src/app/backups
LOG_PATH=/usr/src/app/logs
DB_PATH=/usr/src/app/prisma/gallformers.sqlite

# PM2 Configuration
PM2_MAX_MEMORY=1G
PM2_RESTART_DELAY=2000
PM2_MAX_RESTARTS=20 