# Gallformers V2 Environment Variables
# Copy this file to .env and fill in the values

# Database path (required)
# Local dev: ../prisma/gallformers.sqlite
# Production (Fly.io): /data/gallformers.sqlite
DATABASE_PATH=../prisma/gallformers.sqlite

# Production host for downloading database (optional)
# Used by: make download-db
# Format: user@hostname
PROD_HOST=

# Environment mode (optional)
# Values: development, production
ENVIRONMENT=development
