# Gallformers V2 Environment Variables
# Copy this file to .env and fill in the values
#
# SECRETS STRATEGY:
# - Local dev: All variables go in .env (this file, gitignored)
# - Production: Non-secrets in fly.toml [env], secrets via `fly secrets set`

# =============================================================================
# CORE CONFIGURATION (also in fly.toml for production)
# =============================================================================

# Database path (required)
# Local dev: relative path to shared v1 database
# Production: /data/gallformers.sqlite (on Fly.io volume, set in fly.toml)
DATABASE_PATH=../prisma/gallformers.sqlite

# Environment mode
# Values: development, production
ENVIRONMENT=development

# =============================================================================
# DEVELOPMENT ONLY
# =============================================================================

# Production host for downloading database
# Used by: make download-db
# Format: user@hostname (e.g., root@gallformers.org)
PROD_HOST=

# =============================================================================
# SECRETS - AWS S3 (Image Storage)
# Production: fly secrets set AWS_ACCESS_KEY_ID=xxx AWS_SECRET_ACCESS_KEY=xxx ...
# =============================================================================

# Primary S3 credentials (read access for serving images)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET=

# S3 credentials for presigned upload URLs (write-only, used by admin UI)
# These are separate restricted credentials that can only PUT objects
S3_PUT_AWS_ACCESS_KEY_ID=
S3_PUT_AWS_SECRET_ACCESS_KEY=

# =============================================================================
# SECRETS - AUTH0 (Admin Authentication)
# Production: fly secrets set AUTH0_CLIENT_ID=xxx AUTH0_SECRET=xxx ...
# =============================================================================

# Auth0 application credentials (same as v1)
AUTH0_CLIENT_ID=
AUTH0_SECRET=
AUTH0_DOMAIN=

# Session encryption key (generate with: openssl rand -base64 32)
SESSION_SECRET=

# =============================================================================
# PRODUCTION DEPLOYMENT CHECKLIST
# =============================================================================
# 1. Create Fly.io app: fly apps create gallformers
# 2. Create volume: fly volumes create gallformers_data --region iad --size 1
# 3. Set secrets:
#    fly secrets set \
#      AWS_ACCESS_KEY_ID=xxx \
#      AWS_SECRET_ACCESS_KEY=xxx \
#      AWS_REGION=xxx \
#      S3_BUCKET=xxx \
#      S3_PUT_AWS_ACCESS_KEY_ID=xxx \
#      S3_PUT_AWS_SECRET_ACCESS_KEY=xxx \
#      AUTH0_CLIENT_ID=xxx \
#      AUTH0_SECRET=xxx \
#      AUTH0_DOMAIN=xxx \
#      SESSION_SECRET=xxx
# 4. Deploy: fly deploy
# 5. Verify: fly secrets list (should show all secrets)
