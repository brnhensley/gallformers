# Postgres data loading pipeline config
# Copy to .env.pg-load and fill in values
# See scripts/pg-load.sh and runbooks/postgres-cutover.md

# Fly Postgres credentials
PG_USERNAME=gallformers_preview
PG_PASSWORD=
PG_DB_APP=gallformers-db
PG_DBNAME=gallformers_preview
PG_FLY_APP=gallformers-preview

# Litestream credentials (optional — only needed for production cutover)
LITESTREAM_ACCESS_KEY_ID=
LITESTREAM_SECRET_ACCESS_KEY=
