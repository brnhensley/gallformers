<!DOCTYPE html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />

    <%!-- SEO Meta Tags --%>
    <GallformersWeb.SEO.meta_tags
      title={assigns[:page_title]}
      description={assigns[:page_description]}
      canonical={assigns[:page_url]}
      noindex={assigns[:page_noindex] || false}
    />

    <%!-- Open Graph & Twitter Card Meta Tags --%>
    <GallformersWeb.SEO.og_tags
      title={assigns[:page_title]}
      description={assigns[:page_description]}
      url={assigns[:page_url]}
      image={assigns[:page_image]}
      type={assigns[:page_type] || "website"}
    />

    <.live_title default="Gallformers">
      {assigns[:page_title]}
    </.live_title>

    <%!-- JSON-LD Structured Data (passed from LiveViews) --%>
    {assigns[:page_json_ld]}

    <link rel="icon" href={~p"/favicon.ico"} />
    <link rel="apple-touch-icon" href={~p"/apple-touch-icon.png"} />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
  </head>
  <body class="min-h-screen">
    {@inner_content}
  </body>
</html>
