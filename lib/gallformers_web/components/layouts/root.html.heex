<!DOCTYPE html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />

    <%!-- SEO Meta Tags --%>
    <GallformersWeb.SEO.meta_tags
      title={assigns[:page_title]}
      description={assigns[:page_description]}
      canonical={assigns[:page_url]}
      noindex={assigns[:page_noindex] || false}
    />

    <%!-- Open Graph & Twitter Card Meta Tags --%>
    <GallformersWeb.SEO.og_tags
      title={assigns[:page_title]}
      description={assigns[:page_description]}
      url={assigns[:page_url]}
      image={assigns[:page_image]}
      type={assigns[:page_type] || "website"}
    />

    <.live_title default="Gallformers">
      {assigns[:page_title]}
    </.live_title>

    <%!-- JSON-LD Structured Data (passed from LiveViews) --%>
    <script :if={assigns[:page_json_ld]} type="application/ld+json" nonce={assigns[:csp_nonce]}>
      {Phoenix.HTML.raw(assigns[:page_json_ld])}
    </script>

    <link rel="icon" href={~p"/favicon.ico"} />
    <link rel="apple-touch-icon" href={~p"/apple-touch-icon.png"} />
    <link rel="manifest" href={~p"/manifest.json"} />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script
      defer
      phx-track-static
      type="text/javascript"
      src={~p"/assets/js/app.js"}
      nonce={assigns[:csp_nonce]}
    >
    </script>
  </head>
  <body class="min-h-screen">
    <div
      :if={Application.get_env(:gallformers, :preview_deploy)}
      class="bg-red-600 text-white text-center py-2 font-bold text-sm sticky top-0 z-[100]"
    >
      PREVIEW — this is not production
    </div>
    {@inner_content}
  </body>
</html>
