# OS files
.DS_Store

# Editor
.vscode

# Logs
log.log

# Spell check
cspell.json

# Claude Code settings
.claude/settings.local.json

# Git worktrees
.worktrees/

# Generated tiles for maps
services/tileserver-gl/boundaries.mbtiles

# === Elixir/Phoenix ===

# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where 3rd-party dependencies like ExDoc output generated docs.
/doc/

# Ignore .fetch files in case you like to edit your project deps locally.
/.fetch

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Temporary files, for example, from tests.
/tmp/

# Ignore package tarball (built via "mix hex.build").
gallformers-*.tar

# Ignore assets that are produced by build tools.
/priv/static/assets/

# Ignore digested assets cache.
/priv/static/cache_manifest.json

# Ignore digested/fingerprinted assets (generated by mix phx.digest)
# These have content hashes in filenames and .gz compressed versions
/priv/static/**/*-????????????????????????????????.*
/priv/static/**/*.gz

# In case you use Node.js/npm, you want to ignore these.
npm-debug.log
/assets/node_modules/

# Database files
*.db
*.db-*
# Ignore all SQLite databases in priv/ (dev, test, migration artifacts, etc.)
/priv/*.sqlite
*.sqlite-shm
*.sqlite-wal

# Dialyzer PLT files (large, environment-specific)
/priv/plts/

# Request logs (development only, production uses /data/logs)
/priv/logs/

# API compiled binaries
api/bin/

# Environment secrets
.env
.env.local
.env*.local

# E2E test artifacts (Wallaby)
/test/screenshots/*.png
!/test/screenshots/.gitkeep

# bv (beads viewer) local config and caches
.bv/
.beads/.bv.lock

# OpenTofu / Terraform
.terraform/
*.tfstate
*.tfstate.*
*.tfplan
.terraform.lock.hcl
