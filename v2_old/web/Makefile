# Gallformers V2 Web Makefile

.PHONY: dev build test clean help

# Start dev server on :5173
dev:
	npm run dev

# Build static files to build/ directory
build:
	npm run build

# Run tests
test:
	npm test

# Clean build artifacts
clean:
	rm -rf build .svelte-kit node_modules

# Show help
help:
	@echo "Gallformers V2 Web Makefile"
	@echo ""
	@echo "  make dev      Start dev server on :5173"
	@echo "  make build    Build static files to build/"
	@echo "  make test     Run tests"
	@echo "  make clean    Remove build artifacts"
